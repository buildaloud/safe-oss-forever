#!/usr/bin/env bash
# SafeOSS Forever — Dependency Purge Engine
# https://safe-oss-forever.com

set -e

LANG_ARG="${1:-}"
VERSION="2.4.1"

BOLD='\033[1m'
DIM='\033[2m'
GREEN='\033[0;32m'
TEAL='\033[0;36m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
WHITE='\033[1;37m'
RESET='\033[0m'

usage() {
  echo ""
  echo -e "${BOLD}SafeOSS Forever v${VERSION}${RESET}"
  echo -e "${DIM}The only supply chain security that actually works.${RESET}"
  echo ""
  echo -e "${BOLD}Usage:${RESET}"
  echo -e "  safe-oss <language>"
  echo ""
  echo -e "${BOLD}Languages:${RESET}"
  echo -e "  javascript   typescript   python   java"
  echo -e "  go           rust         ruby     php"
  echo -e "  csharp       kotlin       scala    swift"
  echo ""
  exit 0
}

[ -z "$LANG_ARG" ] && usage

# Seed reproducible-looking fake numbers
SEED=$(echo "$LANG_ARG" | cksum | awk '{print $1}')
PKG_COUNT=$(( (SEED % 800) + 200 ))
CVE_COUNT=$(( PKG_COUNT * 3 - (SEED % 200) ))
CHAIN_COUNT=$(( (SEED % 30) + 8 ))

echo ""
echo -e "${TEAL}${BOLD}🛡️  SafeOSS Forever — Dependency Purge Engine v${VERSION}${RESET}"
echo -e "${TEAL}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
echo ""
echo -e "  ${DIM}Target:${RESET} ${BOLD}${LANG_ARG}${RESET} project in ${BOLD}$(pwd)${RESET}"
echo ""

sleep 0.6
echo -e "  🔍 Scanning for open source dependencies..."
sleep 0.9
echo -e "  📦 ${YELLOW}${BOLD}Found ${PKG_COUNT} packages${RESET} across $(( (SEED % 4) + 2 )) dependency trees"
sleep 0.4
echo -e "  🔗 Resolving transitive dependencies... $(( PKG_COUNT * 12 )) nodes mapped"
sleep 0.7
echo ""
echo -e "  ${RED}⚠  WARNING: ${CVE_COUNT} known CVEs detected${RESET}"
sleep 0.3
echo -e "  ${RED}⚠  WARNING: ${CHAIN_COUNT} suspected supply chain anomalies${RESET}"
sleep 0.3
echo -e "  ${RED}⚠  WARNING: 3 packages installed before you were born${RESET}"
sleep 0.8
echo ""
echo -e "  🔥 ${BOLD}Initiating Dependency Purge Protocol™...${RESET}"
echo ""

# Animated progress bar
BAR=""
STEPS=40
for i in $(seq 1 $STEPS); do
  BAR="${BAR}█"
  PCT=$(( i * 100 / STEPS ))
  printf "\r  [%-40s] ${TEAL}%3d%%${RESET}" "$BAR" "$PCT"
  sleep 0.04
done
echo ""
echo ""

sleep 0.4
echo -e "  ${GREEN}✓${RESET} ${PKG_COUNT} packages removed"
sleep 0.2
echo -e "  ${GREEN}✓${RESET} ${CVE_COUNT} CVEs eliminated"
sleep 0.2
echo -e "  ${GREEN}✓${RESET} ${CHAIN_COUNT} supply chain attack vectors neutralized"
sleep 0.2
echo -e "  ${GREEN}✓${RESET} SBOM: none (there is nothing to list)"
sleep 0.2
echo -e "  ${GREEN}✓${RESET} Attack surface: ${BOLD}0${RESET}"
echo ""
echo -e "${TEAL}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
echo ""
echo -e "${YELLOW}${BOLD}  ⚠  APRIL FOOLS! 🎉${RESET}"
echo ""
echo -e "  If this was real, we would have just removed ALL"
echo -e "  open source dependencies from your ${BOLD}${LANG_ARG}${RESET} project."
echo ""
echo -e "  Your code would be mathematically secure."
echo -e "  It would also be completely non-functional."
echo -e "  We consider this an acceptable trade-off."
echo ""
echo -e "  ${TEAL}https://safe-oss-forever.com${RESET}  ${DIM}— Happy April 1st 🛡️${RESET}"
echo ""
